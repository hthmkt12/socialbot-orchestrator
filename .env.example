# Frontend
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
VITE_GATEWAY_BASE_URL=http://127.0.0.1:8080
VITE_WORKER_BASE_URL=http://127.0.0.1:4310
VITE_MOBILE_MCP_BRIDGE_URL=http://127.0.0.1:4321
# Pilot-only browser encryption key for social account passwords.
# Use 32+ random characters. This is not a production credential vault:
# production social credentials require a later server-side key-management boundary.
VITE_ACCOUNT_PASSWORD_KEY=replace-with-32-plus-random-characters
# auto tries the Edge Function first, browser skips it for local projects without deployed functions.
VITE_RUN_CONTROL_MODE=auto

# Backend / control plane
SUPABASE_URL=https://your-project-ref.supabase.co
# Use the elevated backend key here.
# For newer Supabase projects, prefer an sb_secret_... key.
# Legacy service_role JWT keys also work if that is what the project exposes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
GATEWAY_BASE_URL=http://127.0.0.1:8080
DEVICE_BACKEND=laixi
# Set to mobilerun to enable ai_task step type (requires LLM config below)
# MOBILERUN_LLM_PROVIDER=OpenAIResponses
# MOBILERUN_LLM_MODEL=gpt-4o
# MOBILERUN_LLM_API_KEY=sk-...
MOBILE_MCP_BRIDGE_URL=http://127.0.0.1:4321
# Shared secret for bridge auth. Required unless MOBILE_MCP_ALLOW_INSECURE_DEV=true.
MOBILE_MCP_BRIDGE_TOKEN=replace-with-random-local-bridge-token
# Local-only escape hatch. Do not use outside isolated development.
MOBILE_MCP_ALLOW_INSECURE_DEV=false
# Optional: attempt Mobilerun Portal setup when an Android session starts.
# Leave false for ADB-first local smoke devices that block USB installs.
MOBILE_MCP_ENSURE_PORTAL_ON_SESSION=false
# CORS origin for bridge and gateway. Defaults to http://localhost:5173.
BRIDGE_CORS_ORIGIN=http://localhost:5173
GATEWAY_CORS_ORIGIN=http://localhost:5173
MOBILE_MCP_EXPECTED_SERIALS=QC4DKJUO6PW4FMQW,R58MC1XNTLR
# iOS Portal URLs are also supported (comma-separated):
# MOBILE_MCP_EXPECTED_SERIALS=http://127.0.0.1:6643,http://127.0.0.1:6644
DEVICE_COMMAND_TIMEOUT_MS=15000
GATEWAY_PORT=8080
WORKER_PORT=4310
RUN_POLL_INTERVAL_MS=2000
RUN_LEASE_TTL_MS=15000
WORKER_MAX_ACTIVE_CLAIMS=5
DEVICE_HEALTH_SYNC_INTERVAL_MS=15000

# Optional UI smoke inputs. Do not commit real passwords.
UI_SMOKE_BASE_URL=http://127.0.0.1:5173
UI_SMOKE_EMAIL=codex-ui-operator@example.invalid
UI_SMOKE_PASSWORD=your-test-user-password
UI_SMOKE_DEVICE_MATCHES=23106RN0DA,SM-A515F
UI_SMOKE_APP_NAME=com.android.settings
