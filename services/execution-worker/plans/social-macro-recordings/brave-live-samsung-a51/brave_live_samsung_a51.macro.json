{
  "version": 1,
  "meta": {
    "key": "brave_live_samsung_a51",
    "name": "Social Draft com.brave.browser",
    "tags": [
      "social",
      "draft",
      "review-gated",
      "social-dsl"
    ]
  },
  "inputs": {
    "caption": {
      "type": "string",
      "required": true,
      "description": "Caption or post body"
    }
  },
  "target": {
    "mode": "single_device"
  },
  "execution": {
    "defaultTimeoutMs": 20000,
    "maxRetries": 1,
    "onError": "stop"
  },
  "steps": [
    {
      "id": "launch_app",
      "type": "launch_app",
      "params": {
        "appName": "com.brave.browser"
      }
    },
    {
      "id": "wait_home",
      "type": "wait",
      "params": {
        "ms": 2500
      }
    },
    {
      "id": "open_composer",
      "type": "tap",
      "params": {
        "x": 0.5,
        "y": 0.92,
        "selector": {
          "textContains": "Post",
          "fallback": {
            "x": 0.5,
            "y": 0.92
          }
        }
      }
    },
    {
      "id": "wait_composer",
      "type": "wait",
      "params": {
        "ms": 1500
      }
    },
    {
      "id": "enter_caption",
      "type": "input_text",
      "params": {
        "text": "{{caption}}",
        "x": 0.5,
        "y": 0.35,
        "selector": {
          "fallback": {
            "x": 0.5,
            "y": 0.35
          }
        }
      }
    },
    {
      "id": "capture_draft",
      "type": "screenshot",
      "params": {
        "saveToArtifact": true
      }
    },
    {
      "id": "review_before_publish",
      "type": "approval_checkpoint",
      "params": {
        "reason": "Review social draft before publish"
      }
    },
    {
      "id": "publish_post_approval",
      "type": "approval_checkpoint",
      "params": {
        "reason": "Approve final publish tap"
      }
    },
    {
      "id": "publish_post",
      "type": "tap",
      "params": {
        "x": 0.88,
        "y": 0.08,
        "selector": {
          "text": "Post",
          "fallback": {
            "x": 0.88,
            "y": 0.08
          }
        }
      },
      "policy": {
        "requiresApproval": true
      }
    }
  ]
}
